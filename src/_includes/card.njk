<article class="card">
  <h3><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
  <div class="meta">{{ post.date | readableDate }}{% if post.data.mood %} • {{ post.data.mood }}{% endif %}</div>
  {% if post.data.excerpt %}<p class="small">{{ post.data.excerpt }}</p>{% endif %}
  {% if post.data.tags %}
    <div class="tags">
      {% for t in post.data.tags %}
        {% if t != 'posts' %}<span class="tag">{{ t }}</span>{% endif %}
      {% endfor %}
    </div>
  {% endif %}
</article>
