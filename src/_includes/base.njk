<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{ title }}</title>
  <meta name="description" content="{{ description or 'Nadia\'s Study — clean, minimal writing.' }}" />
  <link rel="stylesheet" href="/styles.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;550;650&family=Source+Serif+4:opsz,wght@8..60,400;8..60,600&display=swap" rel="stylesheet">
</head>
<body>
  <header>
    <nav class="nav">
      <a class="brand" href="/">Nadia</a>
      <div class="links">
        <a href="/" class="{{ 'active' if page.url == '/' }}">Home</a>
        <a href="/writing/" class="{{ 'active' if page.url.startsWith('/writing') }}">Writing</a>
        <a href="/fragments/" class="{{ 'active' if page.url.startsWith('/fragments') }}">Fragments</a>
        <a href="/about/" class="{{ 'active' if page.url.startsWith('/about') }}">About</a>
        <a href="/contact/" class="{{ 'active' if page.url.startsWith('/contact') }}">Contact</a>
        <button class="btn" id="themeBtn" type="button">Theme</button>
      </div>
    </nav>
  </header>

  <main class="wrap">
    {{ content | safe }}

    <footer>
      <div>© <span id="year"></span> Nadia</div>
      <script>document.getElementById('year').textContent = new Date().getFullYear();</script>
    </footer>
  </main>

  <script src="/script.js"></script>
</body>
</html>
